// Device family select
function buildDeviceFamilySelect() {
  const select = document.getElementById("deviceFamilySelect");
  select.innerHTML = '<option value="all">All Devices</option>';
  const groups = categories[currentCat].deviceGroups;
  groups.forEach(g => {
    const opt = document.createElement("option");
    opt.value = g.name;
    opt.textContent = g.name + " (" + g.devices.length + ")";
    select.appendChild(opt);
  });
  select.value = "all";
  select.onchange = () => buildTable();
}

