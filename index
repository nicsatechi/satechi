    const group = cat.deviceGroups.find(g => g.name === familyFilter);
    if (group) countDevices = group.devices;
  }
  
  body.innerHTML = "";
  let count = 0;

  // Sort products by launch date — newest first, undated products at bottom
  function parseLaunchDate(sku) {
    const d = launchDates[sku];
    if (!d) return 0;
    const parts = d.split('/');
    if (parts.length !== 3) return 0;
    return new Date(parseInt(parts[2]), parseInt(parts[0]) - 1, parseInt(parts[1])).getTime();
  }

  const sortedIndices = cat.products
    .map((p, idx) => idx)
    .sort((a, b) => parseLaunchDate(cat.products[b].sku) - parseLaunchDate(cat.products[a].sku));

  sortedIndices.forEach(idx => {
    const p = cat.products[idx];
    const matchesSearch = !query || p.name.toLowerCase().includes(query) || p.sku.toLowerCase().includes(query);
    if (!matchesSearch) return;

    // Filter by subcategory tag
    if (currentSubcat) {
      const tagKey = currentCat + "_" + idx;
      if (productTags[tagKey] !== currentSubcat) return;
    }
    
    let c = 0, n = 0, k = 0;
    countDevices.forEach(d => {
      const s = getStatus(p.compatibility[d] || "unknown");
      if (s === "c") c++;
      else if (s === "n") n++;
      else if (s === "k") k++;
    });

    const tagKey = currentCat + "_" + idx;
    const rowTag = productTags[tagKey] || null;
    const colorClass = catColors[currentCat] || 'blue';
    const rowPill = rowTag
      ? '<span class="row-subcat-pill ' + colorClass + '">' + esc(rowTag) + '</span>'
      : '';

    const launchDate = launchDates[p.sku] || '';
    const launchCell = launchDate
      ? '<span class="row-launch-pill">' + esc(launchDate) + '</span>'
      : '<span class="launch-empty">—</span>';

    const tr = document.createElement("tr");
    tr.dataset.idx = idx;
    tr.innerHTML =
      '<td class="sku-text"><span>' + esc(p.sku) + '</span></td>' +
      '<td><div class="product-cell"><span class="product-text">' + esc(p.name) + '</span></div></td>' +
      '<td style="text-align:center">' + rowPill + '</td>' +
      '<td style="text-align:center">' + launchCell + '</td>' +
      '<td style="text-align:center"><span class="status-badge status-compatible">' + c + '</span></td>';
    
    tr.onclick = () => showDetail(idx);
    body.appendChild(tr);
    count++;
  });

  document.getElementById("statCount").textContent = count;
  document.getElementById("tableTitle").textContent = currentCat;
}


document.getElementById("searchBox").addEventListener("input", () => buildTable());

// Detail panel
function showDetail(idx) {
  currentDetailIdx = idx;
  detailStatusFilter = "all";
  const cat = categories[currentCat];
  const p = cat.products[idx];
  const devices = cat.devices;

  // Highlight row
  document.querySelectorAll("tbody tr").forEach(r => r.classList.remove("active-row"));
  const row = document.querySelector('tbody tr[data-idx="' + idx + '"]');
  if (row) row.classList.add("active-row");

  const productName = esc(p.name);
  const catColorClass = catColors[currentCat] || 'blue';
  const tagKey = currentCat + '_' + idx;
  const assignedTag = productTags[tagKey] || null;
  const subcatPill = assignedTag
    ? '<div class="detail-subcat-pill ' + catColorClass + '">' + esc(assignedTag) + '</div>'
    : '';
  document.getElementById("detailHeader").innerHTML =
    '<h2>' + productName + '</h2>' +
    '<div class="detail-sku"><span>' + esc(p.sku) + '</span></div>' +
    '<div class="detail-cat ' + catColorClass + '">' + esc(currentCat) + '</div>' +
    subcatPill;

  const counts = getCounts(p, devices);

  // Populate specs display from productSpecs if available
  const specsDisplay = document.getElementById("specsDisplay");
  if (specsDisplay) {
    const spec = (typeof productSpecs !== "undefined" && productSpecs[p.sku]) ? productSpecs[p.sku] : "";
    specsDisplay.innerHTML = spec;
    document.getElementById("detailSpecs").style.display = spec ? "" : "none";
  }

  const filterContainer = document.getElementById("detailFilters");
  filterContainer.innerHTML = "";
  [
    { id: "all", label: "All Devices" },
    { id: "c", label: "Compatible (" + counts.c + ")" },
    { id: "n", label: "Incompatible (" + counts.n + ")" }
  ].forEach(f => {
    const btn = document.createElement("button");
    btn.className = "detail-filter-btn" + (detailStatusFilter === f.id ? " active" : "");
    btn.textContent = f.label;
    btn.onclick = () => {
      detailStatusFilter = f.id;
      renderDetailDevices();
      filterContainer.querySelectorAll(".detail-filter-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
    };
    filterContainer.appendChild(btn);
  });

  renderDetailDevices();
  document.getElementById("detailPanel").classList.add("open");
  document.getElementById("detailOverlay").classList.add("open");
}

function renderDetailDevices() {
  const cat = categories[currentCat];
  const p = cat.products[currentDetailIdx];
  const groups = cat.deviceGroups;

  let bodyHtml = "";
  groups.forEach(g => {
    let hasVisible = false;

    // Count how many devices share each comment within this group
    const commentCount = {};
    const commentDeviceMap = {};
    g.devices.forEach(d => {
      const comment = (p.comments && p.comments[d]) ? p.comments[d] : "";
      if (comment) {
        commentCount[comment] = (commentCount[comment] || 0) + 1;
        if (!commentDeviceMap[comment]) commentDeviceMap[comment] = [];
        commentDeviceMap[comment].push(d);
      }
    });
    // Comments shared by more than one device become group-level notes
    const groupComments = new Set(Object.keys(commentCount).length === 1 ? Object.keys(commentCount) : Object.keys(commentCount).filter(c => commentCount[c] === g.devices.length));

    let groupHtml = '<div class="detail-group"><div class="detail-group-title">' + esc(g.name) + '</div>';

    // Render shared comments right below the title, above the device list
    groupComments.forEach(comment => {
      const anyVisible = commentDeviceMap[comment].some(d => {
        const s = getStatus(p.compatibility[d] || "unknown");
        return detailStatusFilter === "all" || s === detailStatusFilter;
      });
      if (anyVisible) {
        groupHtml += '<div class="detail-group-comment">' + esc(comment) + '</div>';
      }
    });

    g.devices.forEach(d => {
      const s = getStatus(p.compatibility[d] || "unknown");
      const comment = (p.comments && p.comments[d]) ? p.comments[d] : "";
      const hidden = (detailStatusFilter !== "all" && s !== detailStatusFilter) ? " hidden-device" : "";
      if (!hidden) hasVisible = true;

      groupHtml += '<div class="detail-device' + hidden + '"><div class="detail-dot ' + s + '"></div><div class="detail-device-info"><div class="detail-device-name">' + esc(d) + '</div>';
      // Only show inline if this comment is unique to this device in the group
      if (comment && !groupComments.has(comment)) {
        groupHtml += '<div class="detail-device-comment">' + esc(comment) + '</div>';
      }
      groupHtml += '</div></div>';
    });

    groupHtml += '</div>';
    if (detailStatusFilter === "all" || hasVisible) bodyHtml += groupHtml;
  });

  document.getElementById("detailBody").innerHTML = bodyHtml;
}

function copyDetailPanel() {
  const cat = categories[currentCat];
  if (currentDetailIdx === null) return;
  const p = cat.products[currentDetailIdx];
  const groups = cat.deviceGroups;

  let plainLines = [];
  let htmlLines = [];

  groups.forEach(g => {
    let groupPlain = [];
    let groupHtml = [];
    g.devices.forEach(d => {
      const s = getStatus(p.compatibility[d] || "unknown");
      if (s !== "c") return;
      groupPlain.push("* " + d);
      groupHtml.push("<li>" + esc(d) + "</li>");
    });
    if (groupPlain.length > 0) {
      plainLines.push(g.name.toUpperCase());
      groupPlain.forEach(l => plainLines.push(l));
      plainLines.push("");
      htmlLines.push("<p><strong>" + esc(g.name.toUpperCase()) + "</strong></p><ul>" + groupHtml.join("") + "</ul><br>");
    }
  });

  // Remove trailing blank line from plain text
  while (plainLines.length && plainLines[plainLines.length - 1] === "") plainLines.pop();

  const plainText = plainLines.join("\n");
  const htmlText = "<meta charset='utf-8'>" + htmlLines.join("");

  const blobHtml = new Blob([htmlText], { type: "text/html" });
  const blobText = new Blob([plainText], { type: "text/plain" });
  const item = new ClipboardItem({ "text/html": blobHtml, "text/plain": blobText });

  const copyBtn = document.getElementById("detailCopy");
  const resetBtn = () => {
    copyBtn.classList.remove("copied");
    copyBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy List';
  };
  const showCopied = () => {
    copyBtn.classList.add("copied");
    copyBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
    setTimeout(resetBtn, 2000);
  };
  navigator.clipboard.write([item]).then(showCopied).catch(() => {
    navigator.clipboard.writeText(plainText).then(showCopied).catch(() => {});
  });
}

function fmtCmd(cmd) {
  document.execCommand(cmd, false, null);
}






function closeDetail() {
  document.getElementById("detailPanel").classList.remove("open");
  document.getElementById("detailOverlay").classList.remove("open");
  document.querySelectorAll("tbody tr").forEach(r => r.classList.remove("active-row"));
  currentDetailIdx = null;
}

document.getElementById("detailClose").addEventListener("click", closeDetail);
document.getElementById("detailCopy").addEventListener("click", copyDetailPanel);
// Handle overlay click (only if clicking on the overlay itself, not the panel)
document.getElementById("detailOverlay").addEventListener("click", function(e) {
  if (e.target === this) closeDetail();
});

// Theme management
function getSystemTheme() {
  return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
}

function applyTheme(theme) {
  document.documentElement.setAttribute('data-theme', theme);
  const icon = document.getElementById('themeIcon');
  const label = document.getElementById('themeLabel');
  if (theme === 'light') {
    icon.innerHTML = '&#9788;';
    label.textContent = 'Light';
  } else {
    icon.innerHTML = '&#9790;';
    label.textContent = 'Dark';
  }
}

function toggleTheme() {
  const current = document.documentElement.getAttribute('data-theme');
  const next = current === 'dark' ? 'light' : 'dark';
  applyTheme(next);
  try { localStorage.setItem('satechi-theme', next); } catch(e) {}
}

// On load: check saved preference, then system preference
(function() {
  let theme;
  try { theme = localStorage.getItem('satechi-theme'); } catch(e) {}
  if (!theme) theme = getSystemTheme();
  applyTheme(theme);
})();

// Listen for system theme changes
window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', e => {
  let saved;
  try { saved = localStorage.getItem('satechi-theme'); } catch(e) {}
  if (!saved) applyTheme(e.matches ? 'light' : 'dark');
});

// Init
buildTabs();
buildStats();
buildSubcats();
buildDeviceFamilySelect();
buildTable();
