let currentSubcat = null;


// Subcategory row
function buildSubcats() {
  const container = document.getElementById("subcatRow");
  container.innerHTML = "";
  const subs = subCategories[currentCat] || [];
  const colorClass = catColors[currentCat] || 'blue';
  subs.forEach(sub => {
    const pill = document.createElement("div");
    pill.className = "subcat-pill " + colorClass + (currentSubcat === sub ? " subcat-pill-active" : "");
    pill.textContent = sub;
    pill.style.cursor = "pointer";
    pill.onclick = () => {
      currentSubcat = (currentSubcat === sub) ? null : sub;
      closeDetail();
      buildSubcats();
      buildTable();
    };
    container.appendChild(pill);
  });
}

// Stats row — now shows category cards as filters
function buildStats() {
  const container = document.getElementById("statsRow");
  container.innerHTML = "";
  catNames.forEach(cat => {
    const colorClass = catColors[cat] || 'blue';
    const card = document.createElement("div");
    card.className = "stat-card " + colorClass + (cat === currentCat ? " stat-card-active" : "");
    card.style.cursor = "pointer";
    card.innerHTML =
      '<div class="stat-value">' + categories[cat].products.length + '</div>' +
      '<div class="stat-label">' + esc(cat) + '</div>';
    card.onclick = () => {
      currentCat = cat;
      currentSubcat = null;
      document.getElementById("searchBox").value = "";
      closeDetail();
      buildStats();
      buildSubcats();
      buildDeviceFamilySelect();
      buildTable();
    };
    container.appendChild(card);
  });
}

