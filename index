const specsData = {};

function saveSpecs() {
  const specsKey = "specs_" + currentCat + "_" + currentDetailIdx;
  specsData[specsKey] = true;
  applySpecsSaved();
}

function editSpecs() {
  const specsKey = "specs_" + currentCat + "_" + currentDetailIdx;
  specsData[specsKey + "_saved"] = false;
  applySpecsEditing();
}

function applySpecsSaved() {
  document.getElementById("specsToolbar").style.display = "none";
  document.getElementById("specsSaveBtn").style.display = "none";
  document.getElementById("specsEditBtn").style.display = "";
}

function applySpecsEditing() {
  document.getElementById("specsToolbar").style.display = "flex";
  document.getElementById("specsSaveBtn").style.display = "";
  document.getElementById("specsEditBtn").style.display = "none";
}

function copySpecs() {
  if (currentDetailIdx === null) return;
  const cat = categories[currentCat];
  const p = cat.products[currentDetailIdx];
  const spec = (typeof productSpecs !== "undefined" && productSpecs[p.sku]) ? productSpecs[p.sku] : "";
  if (!spec) return;

  // Plain text: replace <br> with newlines, strip bold tags, decode entities
  const plainText = spec
    .replace(/<br\s*\/?>/gi, "\n")
    .replace(/<b>/gi, "")
    .replace(/<\/b>/gi, "")
    .replace(/&amp;/g, "&")
    .replace(/&lt;/g, "<")
    .replace(/&gt;/g, ">")
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'");

  const htmlText = "<meta charset='utf-8'>" + spec;

  const btn = document.getElementById("detailCopySpecs");
  const originalHTML = btn.innerHTML;
  const checkSVG = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!';

  const blobHtml = new Blob([htmlText], { type: "text/html" });
  const blobText = new Blob([plainText], { type: "text/plain" });
  const item = new ClipboardItem({ "text/html": blobHtml, "text/plain": blobText });

  navigator.clipboard.write([item]).then(() => {
    btn.innerHTML = checkSVG;
    setTimeout(() => { btn.innerHTML = originalHTML; }, 1500);
  }).catch(() => {
    // Fallback to plain text only
    navigator.clipboard.writeText(plainText).then(() => {
      btn.innerHTML = checkSVG;
      setTimeout(() => { btn.innerHTML = originalHTML; }, 1500);
    });
  });
}

document.addEventListener("DOMContentLoaded", function() {
  document.getElementById("detailCopySpecs").addEventListener("click", copySpecs);
});

